# =============================================================================
# Variables de entorno — Nexa
# =============================================================================
# Copia este archivo como .env y completa los valores de tu proyecto Supabase.
#
#   cp .env.example .env
#
# ⚠️ .env está en .gitignore — NUNCA lo committees.
# Este archivo (.env.example) sí debe committearse como plantilla.
# =============================================================================

# URL de tu proyecto de Supabase (https://app.supabase.com → Settings → API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon Key de Supabase (Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui
