# =============================================================================
# .gitignore — Nexa (Svelte + Vite + TypeScript + PWA)
# =============================================================================
# Compilado para cubrir todos los casos posibles en un proyecto Vite/Svelte
# con Supabase, PWA, testing con Playwright y chart.js.
# =============================================================================


# ─── Dependencias ─────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Build & output ──────────────────────────────────────────────────────────
dist/
dist-ssr/
build/
*.js.map
*.css.map
*.tsbuildinfo

# ─── Vite PWA (dev build — se regenera cada vez que corres vite) ──────────────
dev-dist/

# ─── Entorno / variables de entorno ──────────────────────────────────────────
# NOTA: .env.example sí debe committearse (es la plantilla de variables necesarias)
.env
.env.*.local
.env.development
.env.production
.env.test
.env.local

# ─── Logs & debug ────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
check_output.txt
*-report.html

# ─── Cobertura de tests ──────────────────────────────────────────────────────
coverage/
.coverage/
coverage-ts/
test-results/
playwright-report/

# ─── Cache & temp ────────────────────────────────────────────────────────────
.cache/
.temp/
.tmp/
*.cache
.eslintcache
.stylelintcache

# ─── Directorios del sistema operativo ───────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Editores / IDEs ─────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json    # ← recomendado mantener si quieres compartir extensiones sugeridas
.idea/
*.iml
*.swp
*.swo
*.swn
*.swm
*.sassc
*.suo
*.ntvs*
*.njsproj
*.sln
*.sdf
.vs/
.vscode-insiders/

# ─── Freebuff (app de escritorio — datos locales) ────────────────────────────
.freebuff/

# ─── Archivos de proyecto específicos ─────────────────────────────────────────
*.local
*.tgz
*.tar.gz
*.orig
*.bak
*.patch
*.diff
*~

# ─── Tailwind / PostCSS (si generan output intermedio) ───────────────────────
# (vacío por ahora — Tailwind 4 con Vite no genera archivos intermedios)

# ─── TypeScript (no compilamos — Vite se encarga) ──────────────────────────
tsconfig.tsbuildinfo

# ─── Playwright (tests E2E) ──────────────────────────────────────────────────
playwright/.cache/
